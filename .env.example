# SharePoint Configuration (世纪互联)
SHAREPOINT_SITE_URL=https://test.sharepoint.cn/sites/mcm_ooo
SHAREPOINT_CLIENT_ID=my_sharepoint_client_id
SHAREPOINT_CLIENT_SECRET=my_sharepoint_client_secret
SHAREPOINT_TENANT_ID=my_sharepoint_tenant_id

# Sync Configuration
SHAREPOINT_BASE_FOLDER_NAME=1.开发项目文件；0.0试验基准
SHAREPOINT_SYNC_FOLDERS_PATTERN=开发-*;^[^/]{3,5}$
SHAREPOINT_LOCAL_SYNC_PATH=./data
SHAREPOINT_RETENTION_DAYS=7
SHAREPOINT_BATCH_SIZE=100
SHAREPOINT_MAX_CONCURRENT_DOWNLOADS=5

# Scheduler Configuration
SHAREPOINT_SYNC_INTERVAL_MINUTES=60
SHAREPOINT_CLEANUP_INTERVAL_HOURS=24

# Database Configuration
SHAREPOINT_DATABASE_URL=postgresql://user:password@localhost:5432/sharepoint_sync

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/app.log
